# Flask
SECRET_KEY=change-me-to-a-long-random-string

# Database (Neon PostgreSQL in production; omit for local SQLite)
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Admin (this email gets post CRUD + messages panel; exempt from email verification)
ADMIN_EMAIL=you@example.com

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gmail SMTP (App Password) — contact form + email verification
MAIL_ADDRESS=you@gmail.com
MAIL_APP_PASSWORD=

# Optional
MUSIC_URL=https://res.cloudinary.com/your-cloud/video/upload/relaxing-music.mp3
